{
	"schemaVersion": 1,
	"id": "vanilla-outsider-better-dogs",
	"version": "${version}",
	"name": "Vanilla Outsider: Better Dogs",
	"description": "Enhances wolf AI with personalities and smarter behavior. Includes a dog feeding system from dropped items. (Config: Cloth Config for 1.21.11, Game Rules for 26.1+).",
	"authors": [
		"DasikIgaijin"
	],
	"contact": {
		"homepage": "https://github.com/Rifaditya",
		"sources": "https://github.com/Rifaditya/Vanilla-Outsider-Better-Dogs"
	},
	"license": "GPL-3.0",
	"icon": "assets/vanilla-outsider-better-dogs/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "net.vanillaoutsider.betterdogs.BetterDogs",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "net.vanillaoutsider.betterdogs.BetterDogsClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{
				"value": "net.vanillaoutsider.betterdogs.config.ModMenuIntegration",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"vanilla-outsider-better-dogs.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"cloth-config": "*"
	}
}